# Production (Render tek servis)
ENVIRONMENT=production
SECRET_KEY=change-me-to-a-long-random-string

# Persistent Disk mount noktası (render.yaml ile /var/data)
DATA_DIR=/var/data

# İsteğe bağlı — varsayılan: DATA_DIR/depo_sayim.db
# DATABASE_PATH=/var/data/depo_sayim.db

# İsteğe bağlı — aynı domain deploy'da boş bırakılabilir
# ALLOWED_ORIGINS=https://stoksayim.onrender.com

ACCESS_TOKEN_EXPIRE_MINUTES=480

# Yerel geliştirme için VITE_API_URL boş bırakın (Vite proxy kullanılır)
# VITE_API_URL=
